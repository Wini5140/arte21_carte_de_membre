# ARTE21 – Règles de sécurité Apache

# Encodage UTF-8 par défaut
AddDefaultCharset UTF-8

# Masquer la signature du serveur
ServerSignature Off

# ---- Protection des répertoires sensibles ----

# Empêcher la liste des fichiers dans tous les répertoires
Options -Indexes

# Interdire l'accès direct au répertoire config
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^config/  - [F,L]
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^sql/     - [F,L]
</IfModule>

# ---- En-têtes de sécurité HTTP ----
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    # CSP permissif (style en ligne uniquement depuis le même domaine)
    Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self';"
</IfModule>

# ---- Protection contre la navigation de répertoires ----
<FilesMatch "\.(sql|log|env|bak|cfg|ini)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# ---- Limite de taille d'upload (3 Mo pour la marge) ----
<IfModule mod_php.c>
    php_value upload_max_filesize 3M
    php_value post_max_size 4M
    php_value session.use_strict_mode 1
    php_value session.cookie_httponly 1
    php_value session.cookie_samesite Strict
</IfModule>
